MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_DATABASE=mobivisor
MYSQL_USER=mobivisor_user
MYSQL_PASSWORD=change-this-db-password

FRONTEND_PORT=80
BACKEND_PORT=8081

APP_FRONTEND_URL=http://YOUR_VM_EXTERNAL_IP
CORS_ALLOWED_ORIGINS=http://YOUR_VM_EXTERNAL_IP

VITE_API_URL=http://YOUR_VM_EXTERNAL_IP:8081
ELASTICSEARCH_URIS=http://elasticsearch:9200

MYSQL_BIND_IP=127.0.0.1
ELASTICSEARCH_BIND_IP=127.0.0.1
PHPMYADMIN_BIND_IP=127.0.0.1
PHPMYADMIN_PORT=5050

JWT_SECRET_KEY=replace-with-base64-256-bit-secret
JWT_ACCESS_TOKEN_EXPIRATION=900000
JWT_REFRESH_TOKEN_EXPIRATION=604800000
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAME_SITE=Lax

